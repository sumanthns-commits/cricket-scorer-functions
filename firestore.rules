rules_version = '2';

// Cricket Scorer security rules.
// Cloud Functions use the Admin SDK, which BYPASSES these rules — so all
// stat mutations (careerStats via FieldValue.increment, claim merges, etc.)
// happen server-side and are intentionally NOT writable from the client here.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isMember(clubId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/clubs/$(clubId)/players/$(request.auth.uid));
    }
    function isAdmin(clubId) {
      return isMember(clubId)
        && get(/databases/$(database)/documents/clubs/$(clubId)/players/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users (public-ish profile docs) ──
    match /users/{uid} {
      allow read: if isSignedIn();              // resolve display names, etc.
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Club membership index ──
    match /userMemberships/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Public per-club player stats mirror ──
    // Server-written (Admin SDK via mirrorPlayerStats) copy of each registered
    // player's career stats, keyed `${uid}_${clubId}`. Readable by any signed-in
    // user so a club admin can review a join requester's record across every club
    // they belong to — without exposing the (member-private) club player docs.
    match /publicPlayerStats/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Club name registry ──
    // Enforces unique club names without exposing the (member-private) clubs
    // collection. Doc id = normalised name. Anyone signed in may read (to check
    // availability / run the create transaction) and reserve a name for a club
    // they own. Reservations are released only by the Admin SDK (cleanup fn).
    match /clubNames/{nameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Clubs ──
    match /clubs/{clubId} {
      // Any signed-in user can read the club doc (name, description, hemisphere)
      // so non-members can preview a club before requesting to join.
      // Subcollections (players, matches, etc.) remain member-only.
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin(clubId);
      allow delete: if false;

      // ── Players ──
      match /players/{playerId} {
        // Any club member may view any player's profile.
        allow read: if isMember(clubId);

        // Bootstrap: the club creator makes their own (admin) player doc.
        // Otherwise only an existing admin can add players.
        allow create: if isAdmin(clubId)
          || (request.auth.uid == playerId
              && get(/databases/$(database)/documents/clubs/$(clubId)).data.createdBy == request.auth.uid);

        // Admins may edit any player; a member may edit only their own — and only
        // the editable profile fields. careerStats / type / activeClaim
        // are NOT in this set, so they can never be changed from the client.
        // strengthOverride and role are admin-only.
        allow update: if isAdmin(clubId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['displayName', 'battingHand', 'bowlingStyle', 'wicketKeeping', 'photoURL', 'strengthOverride', 'role'])
          || (request.auth.uid == playerId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['displayName', 'battingHand', 'bowlingStyle', 'wicketKeeping', 'photoURL']);

        allow delete: if isAdmin(clubId);
      }

      // ── Matches + overs (live scoring) ──
      match /matches/{matchId} {
        allow read, create, update: if isMember(clubId);
        allow delete: if isAdmin(clubId);

        match /overs/{overId} {
          allow read, write: if isMember(clubId);
        }
      }

      // ── Claims (created/merged by Cloud Functions only) ──
      match /claims/{claimId} {
        allow read: if isMember(clubId);
        allow write: if false;
      }

      // ── Join requests ──
      // A non-member raises a request to join (doc id = their own uid, so one
      // open request per club). Admins list/read pending requests; the requester
      // can read their own status and cancel it. Approval/rejection is performed
      // only by the resolveJoinRequest Cloud Function (Admin SDK), never the
      // client — hence update is closed here.
      match /joinRequests/{requestId} {
        allow create: if isSignedIn()
          && request.auth.uid == requestId
          && request.resource.data.status == 'pending';
        allow read: if isAdmin(clubId) || request.auth.uid == requestId;
        allow delete: if request.auth.uid == requestId;
        allow update: if false;
      }
    }
  }
}
